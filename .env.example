# ============================================================
# NEXORA — Environment Configuration (EXAMPLE / TEMPLATE)
# Copy this to .env and fill in what you need.
#   cp .env.example .env
# NEXORA runs fully on the deterministic rule engine with NO
# keys at all — every variable below is optional.
# ============================================================

# ------------------------------------------------------------
# LLM PROVIDER — pick ANY one. Both OpenRouter and NVIDIA are FREE.
# You only need ONE key. NEXORA auto-detects whichever is present,
# in priority order: openrouter -> nvidia -> gemini -> openai-compatible.
# ------------------------------------------------------------

# --- Option A: OpenRouter (FREE, recommended) -------------------------------
# Get a key at https://openrouter.ai/keys  (free models, no credit card)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional — defaults to the auto-selecting free router:
OPENROUTER_MODEL=openrouter/free

# --- Option B: NVIDIA NIM (FREE) --------------------------------------------
# Get a key at https://build.nvidia.com  (1000 free credits, key starts nvapi-)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Option C: Google Gemini -------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# --- Option D: ANY OpenAI-compatible endpoint (Groq, Together, Fireworks,
#     DeepInfra, a self-hosted vLLM server, etc.) -----------------------------
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=

# --- Explicit override (wins over auto-detection) ---------------------------
# Set provider + key + model + base_url directly if you prefer:
# LLM_PROVIDER=openrouter|nvidia|gemini|openai_compatible
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# --- Optional resilience: a second provider tried if the primary fails ------
# LLM_FALLBACK_PROVIDER=nvidia
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_MODEL=

# --- Local Ollama (free, offline) — tried before the rule engine ------------
NEXORA_USE_LOCAL=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------
# AGENT LOOP
# ------------------------------------------------------------
NEXORA_CYCLE_SECONDS=60
NEXORA_API_WS=ws://localhost:8000/ws
NEXORA_WORLD_TICK_SECONDS=300
NEXORA_ENV=development
NEXORA_LOG_LEVEL=info

# ------------------------------------------------------------
# PERSISTENCE (optional — audit trail falls back to a local JSONL file)
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_KEY=
NEXORA_HMAC_KEY=change-me-in-production

# ------------------------------------------------------------
# ALERTING (optional — Telegram). TELEGRAM_CHAT must be a NUMERIC chat id.
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT=

# ------------------------------------------------------------
# API
# ------------------------------------------------------------
# Comma-separated allowed origins, or * for any (dev only)
NEXORA_CORS_ORIGINS=*
