FROM python:3.11-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# The API imports the agent package and reads the LogHub data, so both ship in the image.
COPY agent/ ./agent/
COPY api/ ./api/
COPY loghub/ ./loghub/
COPY tests/ ./tests/
ENV PYTHONUNBUFFERED=1
EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
